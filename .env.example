# Spotify API - Requis pour la recherche d'albums via Spotify
# Obtenir sur https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# MusicBrainz - API publique, pas de clé requise

# Base de données Neon (Postgres serverless)
# Obtenir la connection string sur https://console.neon.tech
DATABASE_URL=

# Better Auth
# Générer le secret avec : openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3005
NEXT_PUBLIC_APP_URL=http://localhost:3005
